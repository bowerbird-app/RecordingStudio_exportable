<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Template Demo",
    subtitle: "This dummy app is the browser-facing demo surface for the template, including access-aware export actions.",
    variant: :h1
  ) %>

  <p class="text-sm text-(--surface-muted-content-color)">
    Current actor: <code><%= @current_actor_email || "none" %></code>
    • Dashboard view: <code><%= @dashboard_view_allowed ? "true" : "false" %></code>
    • Dashboard admin: <code><%= @dashboard_admin_allowed ? "true" : "false" %></code>
    • Article export allowed: <code><%= @article_export_allowed ? "true" : "false" %></code>
  </p>

  <p class="text-xs text-(--surface-muted-content-color)">
    Dashboard export keys: <code><%= @dashboard_allowed_export_keys.join(", ") %></code>
  </p>

  <div class="space-y-8">
    <section class="space-y-3">
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Demo API requests"
      ) %>

      <p class="text-sm text-(--surface-muted-content-color)">Required role: <code>view</code></p>

      <% if @demo_dashboard && @demo_recording %>
        <%= recording_studio_export_access_button(
          context_recording: @demo_recording,
          export_key: "recording_studio_demo_dashboard_requests_export",
          text: "Export API requests",
          style: :secondary,
          size: :md,
          unauthorized_behavior: :disable,
          unauthorized_text: "Export restricted"
        ) %>

        <% rows = Array(@demo_dashboard.demo_api_requests).map do |request|
             {
               path: request.path,
               method: request.http_method,
               status: request.status,
               duration: "#{request.duration_ms} ms"
             }
           end %>

        <%= render FlatPack::Table::Component.new(data: rows, class: "text-sm") do |table| %>
          <% table.column(title: "Path") { |row| row[:path] } %>
          <% table.column(title: "Method") { |row| row[:method] } %>
          <% table.column(title: "Status") { |row| row[:status] } %>
          <% table.column(title: "Duration") { |row| row[:duration] } %>
        <% end %>
      <% else %>
        <p class="text-sm leading-6">Run <code>bin/rails db:seed</code> to create demo dashboard data.</p>
      <% end %>
    </section>

    <section class="space-y-3">
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Articles"
      ) %>

      <p class="text-sm text-(--surface-muted-content-color)">Required role: <code>admin</code></p>

      <% if @article_rows.any? %>
        <%= recording_studio_export_access_button(
          context_recording: @demo_recording || @article_rows.first[:context_recording],
          export_key: "recording_studio_article_export",
          text: "Export Articles",
          style: :secondary,
          size: :md,
          unauthorized_behavior: :disable,
          unauthorized_text: "Export Articles (admin required)"
        ) %>

        <%= render FlatPack::Table::Component.new(data: @article_rows, class: "text-sm") do |table| %>
          <% table.column(title: "Article") { |row| row[:title] } %>
          <% table.column(title: "Author") { |row| row[:author_name] } %>
          <% table.column(title: "Topics") { |row| row[:topic_count] } %>
          <% table.column(title: "Word count") { |row| row[:word_count] } %>
        <% end %>
      <% else %>
        <p class="text-sm leading-6">Run <code>bin/rails db:seed</code> to create demo article data.</p>
      <% end %>
    </section>

    <section class="space-y-3">
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Article topics and authors"
      ) %>

      <p class="text-sm text-(--surface-muted-content-color)">Required role: <code>view</code></p>

      <% if @article_topic_rows.any? %>
        <p class="text-xs text-(--surface-muted-content-color)">
          Showing <%= @article_topic_rows_page.length %> of <%= @article_topics_total_rows %> rows on page <%= @article_topics_page %> of <%= @article_topics_total_pages %>. Export includes all matching rows, not just this page.
        </p>

        <%= recording_studio_export_access_button(
          context_recording: @demo_recording || @article_rows.first[:context_recording],
          export_key: "recording_studio_article_topics_authors_export",
          text: "Export Articles with Authors and Topics",
          style: :secondary,
          size: :md,
          unauthorized_behavior: :disable,
          unauthorized_text: "Export restricted"
        ) %>

        <%= render FlatPack::Table::Component.new(data: @article_topic_rows_page, class: "text-sm") do |table| %>
          <% table.column(title: "Article") { |row| row[:article_title] } %>
          <% table.column(title: "Topic") { |row| row[:topic_name] } %>
          <% table.column(title: "Author") { |row| row[:author_name] } %>
        <% end %>

        <% if @article_topics_total_pages > 1 %>
          <div class="flex items-center gap-3 text-sm">
            <% previous_page = @article_topics_page - 1 %>
            <% next_page = @article_topics_page + 1 %>

            <% if @article_topics_page > 1 %>
              <%= link_to "Previous", url_for(request.query_parameters.merge(article_topics_page: previous_page)), class: "underline" %>
            <% else %>
              <span class="text-(--surface-muted-content-color)">Previous</span>
            <% end %>

            <span class="text-(--surface-muted-content-color)">Page <%= @article_topics_page %> / <%= @article_topics_total_pages %></span>

            <% if @article_topics_page < @article_topics_total_pages %>
              <%= link_to "Next", url_for(request.query_parameters.merge(article_topics_page: next_page)), class: "underline" %>
            <% else %>
              <span class="text-(--surface-muted-content-color)">Next</span>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm leading-6">Run <code>bin/rails db:seed</code> to create article topics.</p>
      <% end %>
    </section>

    <section class="space-y-3">
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Topics"
      ) %>

      <p class="text-sm text-(--surface-muted-content-color)">Required role: <code>admin</code></p>

      <%= form_with url: root_path, method: :get, local: true, class: "grid gap-3 md:grid-cols-3" do %>
        <label class="flex flex-col gap-1 text-sm">
          <span class="text-(--surface-muted-content-color)">Filter by topic</span>
          <input type="text" name="topic" value="<%= @topic_filter %>" class="rounded-md border border-(--surface-border-color) bg-(--surface-base-color) px-3 py-2 text-sm" placeholder="topic name" />
        </label>

        <label class="flex flex-col gap-1 text-sm">
          <span class="text-(--surface-muted-content-color)">Filter by article</span>
          <input type="text" name="article" value="<%= @article_filter %>" class="rounded-md border border-(--surface-border-color) bg-(--surface-base-color) px-3 py-2 text-sm" placeholder="article title" />
        </label>

        <div class="flex items-end gap-2">
          <%= render FlatPack::Button::Component.new(text: "Apply filters", type: "submit", style: :primary, size: :md) %>
          <%= link_to "Reset", root_path, class: "text-sm text-(--surface-muted-content-color) underline" %>
        </div>
      <% end %>

      <% if @topic_article_rows.any? && @demo_recording %>
        <p class="text-xs text-(--surface-muted-content-color)">
          Showing <%= @topic_article_rows_page.length %> of <%= @topics_total_rows %> rows on page <%= @topics_page %> of <%= @topics_total_pages %>. Export includes all matching rows, not just this page.
        </p>

        <%= recording_studio_export_access_button(
          context_recording: @demo_recording,
          export_key: "recording_studio_topics_articles_export",
          filters: { topic: @topic_filter, article: @article_filter },
          text: "Export Topics",
          style: :secondary,
          size: :md,
          unauthorized_behavior: :disable,
          unauthorized_text: "Export Topics (admin required)"
        ) %>

        <%= render FlatPack::Table::Component.new(data: @topic_article_rows_page, class: "text-sm") do |table| %>
          <% table.column(title: "Topic") { |row| row[:topic_name] } %>
          <% table.column(title: "Articles") { |row| row[:article_titles] } %>
        <% end %>

        <% if @topics_total_pages > 1 %>
          <div class="flex items-center gap-3 text-sm">
            <% previous_page = @topics_page - 1 %>
            <% next_page = @topics_page + 1 %>

            <% if @topics_page > 1 %>
              <%= link_to "Previous", url_for(request.query_parameters.merge(topics_page: previous_page)), class: "underline" %>
            <% else %>
              <span class="text-(--surface-muted-content-color)">Previous</span>
            <% end %>

            <span class="text-(--surface-muted-content-color)">Page <%= @topics_page %> / <%= @topics_total_pages %></span>

            <% if @topics_page < @topics_total_pages %>
              <%= link_to "Next", url_for(request.query_parameters.merge(topics_page: next_page)), class: "underline" %>
            <% else %>
              <span class="text-(--surface-muted-content-color)">Next</span>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm leading-6">Run <code>bin/rails db:seed</code> to create topic data.</p>
      <% end %>
    </section>

    <section class="space-y-3">
      <%= render FlatPack::SectionTitle::Component.new(
        title: "Documents"
      ) %>

      <p class="text-sm text-(--surface-muted-content-color)">Page access role: <code>admin</code> • Export role: <code>view</code></p>

      <% if @documents.any? %>
        <%= render FlatPack::Table::Component.new(data: @documents, class: "text-sm") do |table| %>
          <% table.column(title: "Document") { |row| link_to(row.title, document_path(row), class: "underline") } %>
          <% table.column(title: "Items") { |row| row.items.count } %>
        <% end %>
      <% else %>
        <p class="text-sm leading-6">Run <code>bin/rails db:seed</code> to create document data.</p>
      <% end %>
    </section>

  </div>
</div>
