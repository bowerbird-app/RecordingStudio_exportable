<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Template Demo",
    subtitle: "This dummy app is the browser-facing demo surface for the template.",
    variant: :h1
  ) %>

  <div class="grid gap-6 lg:grid-cols-2">
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Export demo",
          subtitle: "Generate an authorized CSV from an in-memory Recording Studio export definition.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <% if @demo_dashboard && @demo_recording %>
          <div class="space-y-4">
            <p class="text-sm leading-6 text-(--surface-content-color)">
              The export is registered as <code>demo.dashboard_requests</code>, authorized through
              <code>RecordingStudioAccessible.authorized?</code>, and streamed from memory as CSV.
            </p>

            <%= recording_studio_export_button(
              context_recording: @demo_recording,
              export_key: "demo.dashboard_requests",
              text: "Export API requests",
              style: :primary,
              size: :md
            ) %>
          </div>
        <% else %>
          <p class="text-sm leading-6">Run <code>bin/rails db:seed</code> to create demo export data.</p>
        <% end %>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Next steps",
          subtitle: "The usual first moves when turning the template into a real addon.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <ol class="space-y-3 text-sm leading-6 list-decimal pl-5">
          <li>Register export definitions with stable namespaced keys.</li>
          <li>Enable <code>:exportable</code> on each supported Recording Studio recordable type.</li>
          <li>Use the engine POST endpoint to stream sanitized CSV downloads.</li>
          <li>Inspect export logs to confirm file name, row count, and actor metadata.</li>
        </ol>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Demo API requests",
          subtitle: "Rows included in the sample export.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <% rows = Array(@demo_dashboard&.demo_api_requests).map do |request|
             {
               path: request.path,
               method: request.http_method,
               status: request.status,
               duration: "#{request.duration_ms} ms"
             }
           end %>

        <%= render FlatPack::Table::Component.new(data: rows, class: "text-sm") do |table| %>
          <% table.column(title: "Path") { |row| row[:path] } %>
          <% table.column(title: "Method") { |row| row[:method] } %>
          <% table.column(title: "Status") { |row| row[:status] } %>
          <% table.column(title: "Duration") { |row| row[:duration] } %>
        <% end %>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "FlatPack usage",
          subtitle: "This page uses FlatPack components for its primary UI structure.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <p class="text-sm leading-6 text-(--surface-content-color)">
          Use FlatPack cards, buttons, badges, inputs, and layout primitives as the default path for addon UI. Keep raw HTML for simple semantic content only.
        </p>
      <% end %>

      <% card.footer do %>
        <a href="https://github.com/bowerbird-app/flatpack"
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex">
          <%= render FlatPack::Button::Component.new(
            text: "View FlatPack documentation",
            style: :primary,
            size: :md
          ) %>
        </a>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Install flow",
          subtitle: "What the host app generator path covers.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <ul class="space-y-3 text-sm leading-6">
          <li>Add the gem to your host app and run <code>bundle install</code>.</li>
          <li>Run <code>rails generate recording_studio_exportable:install</code> to mount the engine and add configuration.</li>
          <li>Run <code>rails generate recording_studio_exportable:migrations</code> to copy engine migrations into the host app.</li>
          <li>Rebuild Tailwind if needed with <code>bin/rails tailwindcss:build</code>.</li>
        </ul>
      <% end %>
    <% end %>
  </div>
</div>
